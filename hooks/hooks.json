{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script ${CURSOR_PLUGIN_ROOT}/scripts/sync.py",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "uv run --script ${CURSOR_PLUGIN_ROOT}/scripts/dashboard.py &",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
